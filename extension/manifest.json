{
  "manifest_version": 3,
  "name": "Study Space Widget",
  "version": "1.0",
  "description": "Opens Study Space as a floating widget alongside any page",
  "permissions": ["windows", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
